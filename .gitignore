# ============================================
# CWE Plugin .gitignore
# Protects private/local data from being pushed
# ============================================

# --- Private / User-local (NEVER commit) ---
.claude/cwe-settings.yml
.claude/agent-memory/
.claude/agent-memory-local/
docs/plans/
*.local.md
*.local.json
*.local.yml

# Private commands / skills (project-specific, not for public distribution)
commands/doj-scrape.md
commands/doj-search.md
commands/newsroom.md
skills/newsroom/
memory/.archive/

# --- Credentials & Secrets ---
.env*
*.pem
*.key
*.pfx
*.p12
*.crt
id_rsa*
id_ed25519*
id_ecdsa*
scripts/media-keys.sh

# --- IDE / Editor ---
.vscode/settings.json
.vscode/*.code-workspace
.idea/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Dependencies ---
node_modules/
__pycache__/
.venv/
vendor/

# --- Build / Cache ---
dist/
build/
*.pyc
.cache/

# --- Multi-Terminal (generated in target projects) ---
.trees/
shared/handoff/.changelog
terminal-prompts/

# --- Tool caches ---
.serena/
_backup/
